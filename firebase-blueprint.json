{
  "entities": {
    "SharedPhoto": {
      "title": "Shared Photo",
      "description": "Images generated by the AI photobooth and shared by users.",
      "type": "object",
      "properties": {
        "imageData": {
          "type": "string",
          "description": "Base64 encoded JPEG data"
        },
        "createdAt": {
          "type": "number",
          "description": "Creation timestamp in milliseconds"
        }
      },
      "required": [
        "imageData",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "/shared_photos/{photoId}": {
      "schema": {
        "$ref": "#/entities/SharedPhoto"
      },
      "description": "Stores shared photos generated by users"
    }
  }
}
